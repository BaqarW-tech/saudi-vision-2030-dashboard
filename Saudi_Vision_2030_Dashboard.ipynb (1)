  \"gdp_growth\",\n","    \"NY.GDP.PETR.RT.ZS\":    \"oil_rents_pct_gdp\",\n","    \"SL.EMP.TOTL.SP.NE.ZS\": \"employment_rate\",\n","    \"BX.KLT.DINV.WD.GD.ZS\": \"FDI_pct_GDP\",\n","}\n","\n","date_range = (datetime.datetime(2015, 1, 1), datetime.datetime(2024, 12, 31))\n","\n","print(\"⏳ Fetching data from World Bank API...\")\n","raw = wbdata.get_dataframe(indicators, country=\"SAU\", date=date_range)\n","df_raw = raw.reset_index().rename(columns={\"date\": \"Year\"})\n","df_raw[\"Year\"] = df_raw[\"Year\"].astype(int)\n","df_raw = df_raw.sort_values(\"Year\").reset_index(drop=True)\n","\n","print(\"✅ Raw data fetched.\")\n","\n","# ============================================================\n","# PART 2: Handle missing oil_rents_pct_gdp (World Bank data lag)\n","# ============================================================\n","# The World Bank publishes oil rents with a 1-2 year lag.\n","# 2022-2024 values are missing. We apply forward-fill as a stopgap,\n","# then flag those rows so the chart can show them differently.\n","# Replace with actual GASTAT/SAMA figures when available.\n","\n","missing_oil_years = df_raw[df_raw[\"oil_rents_pct_gdp\"].isna()][\"Year\"].tolist()\n","\n","df_raw[\"oil_rents_filled\"]   = df_raw[\"oil_rents_pct_gdp\"].ffill()\n","df_raw[\"oil_rents_imputed\"]  = df_raw[\"oil_rents_pct_gdp\"].isna()  # True = estimated\n","\n","if missing_oil_years:\n","    print(f\"⚠️  Oil rents data missing for {missing_oil_years}.\")\n","    print(f\"   Forward-filled from last known value as a placeholder.\")\n","    print(f\"   These years will appear as dashed on the chart.\")\n","\n","# ============================================================\n","# PART 3: Approximate non-oil GDP growth\n","# ============================================================\n","# APPROXIMATION NOTE:\n","# non_oil_GDP_growth ≈ total_GDP_growth − Δ(oil_rents_pct_GDP)\n","# This is a simplification. True non-oil GDP requires sector-level\n","# national accounts from GASTAT. Use this for directional analysis only.\n","# Forward-filled oil rents for 2022-2024 make those estimates doubly approximate.\n","\n","df_raw[\"oil_rents_change\"]    = df_raw[\"oil_rents_filled\"].diff()\n","df_raw[\"non_oil_GDP_growth\"]  = df_raw[\"gdp_growth\"] - df_raw[\"oil_rents_change\"]\n","\n","# ============================================================\n","# PART 4: Build the clean dashboard DataFrame\n","# ============================================================\n","\n","df = pd.DataFrame({\n","    \"Year\":               df_raw[\"Year\"],\n","    \"non_oil_GDP_growth\": df_raw[\"non_oil_GDP_growth\"].round(2),\n","    \"oil_rents_imputed\":  df_raw[\"oil_rents_imputed\"],   # flag column\n","    \"employment_rate\":    df_raw[\"employment_rate\"].round(2),\n","    \"FDI_pct_GDP\":        df_raw[\"FDI_pct_GDP\"].round(2),\n","    \"saudization_rate\":   None,\n","})\n","\n","# Drop 2015 — diff() always produces NaN for the first row\n","df = df[df[\"Year\"] >= 2016].reset_index(drop=True)\n","\n","print(\"\\n✅ Clean dashboard DataFrame:\")\n","print(df.to_string(index=False))\n","\n","# ============================================================\n","# PART 5: Vision 2030 Targets\n","# ============================================================\n","\n","targets = {\n","    \"non_oil_GDP_growth\": 6.0,\n","    \"employment_rate\":    70.0,\n","    \"FDI_pct_GDP\":        5.7,\n","    \"saudization_rate\":   None,\n","}\n","\n","# ============================================================\n","# PART 6: Chart — Non-Oil GDP Growth with data quality signals\n","# ============================================================\n","# Solid blue  = confirmed World Bank data\n","# Dashed blue = estimated (forward-filled oil rents used)\n","# Red dashed  = Vision 2030 target\n","\n","confirmed = df[df[\"oil_rents_imputed\"] == False]\n","estimated  = df[df[\"oil_rents_imputed\"] == True]\n","\n","# Connect the two segments at the boundary so the line doesn't break\n","boundary_year = estimated[\"Year\"].min()\n","boundary_row  = confirmed[confirmed[\"Year\"] == boundary_year - 1]\n","estimated_plot = pd.concat([boundary_row, estimated], ignore_index=True)\n","\n","fig, ax = plt.subplots(figsize=(12, 5))\n","\n","target_val  = targets[\"non_oil_GDP_growth\"]\n","target_line = [target_val] * len(df)\n","\n","# Target line\n","ax.plot(df[\"Year\"], target_line,\n","        color=\"crimson\", linewidth=2, linestyle=\"--\",\n","        label=f\"Vision 2030 Target ({target_val} دست)\", zorder=1)\n","\n","# Gap shading\n","ax.fill_between(df[\"Year\"], df[\"non_oil_GDP_growth\"], target_line,\n","                alpha=0.07, color=\"crimson\")\n","\n","# Confirmed data (solid)\n","ax.plot(confirmed[\"Year\"], confirmed[\"non_oil_GDP_growth\"],\n","        color=\"steelblue\", linewidth=2.5, marker=\"o\", markersize=6,\n","        label=\"Actual — confirmed data\", zorder=3)\n","\n","# Estimated data (dashed)\n","ax.plot(estimated_plot[\"Year\"], estimated_plot[\"non_oil_GDP_growth\"],\n","        color=\"steelblue\", linewidth=2, linestyle=\":\", marker=\"o\",\n","        markersize=5, alpha=0.7,\n","        label=\"Estimated — oil rents forward-filled (replace with GASTAT)\", zorder=2)\n","\n","# Reference line at zero\n","ax.axhline(0, color=\"gray\", linewidth=0.8, linestyle=\"-\", alpha=0.5)\n","\n","ax.set_title(\n","    \"Saudi Arabia — Non-Oil GDP Growth vs Vision 2030 Target (2016–2024)\\n\"\n","    \"2016–2021: World Bank approximation  |  2022–2024: GASTAT National Accounts  |  Targets: Vision 2030\",\n","    fontsize=12, fontweight=\"bold\", pad=12\n",")\n","ax.set_xlabel(\"Year\", fontsize=11)\n","ax.set_ylabel(\"Growth (%)\", fontsize=11)\n","ax.yaxis.set_major_formatter(mtick.PercentFormatter(xmax=100, decimals=1))\n","ax.set_xticks(df[\"Year\"])\n","ax.tick_params(axis=\"x\", rotation=45)\n","ax.legend(fontsize=9, loc=\"upper left\")\n","ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.4)\n","\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"\\n✅ Done.\")\n","print(\"   · Solid line   = World Bank confirmed figures\")\n","print(\"   · Dotted line  = estimated (oil rents gap filled forward)\")\n","print(\"   · Next step: fetch GASTAT oil sector data to replace dotted segment\")"],"metadata":{"id":"LjxibkMA-vyJ","colab":{"base_uri":"https://localhost:8080/","height":509},"executionInfo":{"status":"ok","timestamp":1774848925396,"user_tz":-300,"elapsed":1649,"user":{"displayName":"More Wagan","userId":"17960663785126807612"}},"outputId":"f8986aa2-f3cf-455c-cf95-be5f7214ca6e"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["⏳ Fetching data from World Bank API...\n","✅ Raw data fetched.\n","⚠️  Oil rents data missing for [2022, 2023, 2024].\n","   Forward-filled from last known value as a placeholder.\n","   These years will appear as dashed on the chart.\n","\n","✅ Clean dashboard DataFrame:\n"," Year  non_oil_GDP_growth  oil_rents_imputed  employment_rate  FDI_pct_GDP saudization_rate\n"," 2016                5.66              False              NaN         3.19             None\n"," 2017               -2.43              False            51.67         0.14             None\n"," 2018               -1.24              False            52.61         1.37             None\n"," 2019                5.41              False            54.63         0.35             None\n"," 2020                4.55              False            54.96         0.21             None\n"," 2021               -1.19              False            57.10         2.89             None\n"," 2022               12.00               True            57.64         2.16             None\n"," 2023                0.54               True            63.93         1.87             None\n"," 2024                2.00               True            63.96         1.72             None\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image