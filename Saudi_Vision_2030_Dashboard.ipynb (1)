ision 2030 Dashboard - Google Colab Starter\n","# ============================================================\n","\n","# PART 1: Import libraries\n","# pandas handles data tables; matplotlib draws charts\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import matplotlib.ticker as mtick\n","\n","# ============================================================\n","# PART 1: Create the DataFrame with mock data (2015–2024)\n","# ============================================================\n","# Each list represents yearly values for one indicator.\n","# Replace these numbers with real data when you're ready.\n","\n","years = list(range(2015, 2025))  # [2015, 2016, ..., 2024]\n","\n","data = {\n","    \"Year\":                years,\n","    \"Non_Oil_GDP_Growth\":  [1.2, 0.8, 1.5, 2.3, 3.1, 2.8, -1.2, 4.0, 5.1, 4.7],  # %\n","    \"Employment_Rate\":     [52.1, 52.8, 53.4, 54.0, 54.9, 55.7, 54.3, 55.0, 56.2, 57.4],  # %\n","    \"FDI_Inflows\":         [1.4, 1.2, 1.0, 1.3, 1.5, 1.4, 0.9, 1.6, 2.1, 2.4],  # % of GDP\n","    \"Saudization_Rate\":    [40.1, 41.3, 42.0, 43.5, 45.0, 46.2, 47.1, 49.3, 51.0, 53.2],  # %\n","}\n","\n","df = pd.DataFrame(data)\n","print(\"✅ DataFrame created:\")\n","print(df.to_string(index=False))\n","\n","# ============================================================\n","# PART 2: Define Vision 2030 targets for each indicator\n","# ============================================================\n","# These are the official end-state targets (by 2030).\n","# The target line on each chart will be drawn as a flat horizontal line.\n","# Replace values below with real official targets when confirmed.\n","\n","targets = {\n","    \"Non_Oil_GDP_Growth\":  6.0,   # Target: 6% annual growth\n","    \"Employment_Rate\":     70.0,  # Target: 70% employment rate\n","    \"FDI_Inflows\":         5.7,   # Target: 5.7% of GDP\n","    \"Saudization_Rate\":    80.0,  # Target: 80% Saudization\n","}\n","\n","print(\"\\n✅ Vision 2030 Targets:\")\n","for indicator, target in targets.items():\n","    print(f\"  {indicator}: {target}%\")\n","\n","# ============================================================\n","# PART 3: Line chart — Non-Oil GDP Growth: Actual vs Target\n","# ============================================================\n","# We pick one indicator to chart. The blue line is actual data;\n","# the red dashed line is the Vision 2030 target (flat across all years).\n","\n","indicator     = \"Non_Oil_GDP_Growth\"\n","target_value  = targets[indicator]\n","target_line   = [target_value] * len(years)  # same value repeated for each year\n","\n","fig, ax = plt.subplots(figsize=(10, 5))\n","\n","# Actual line\n","ax.plot(\n","    df[\"Year\"], df[indicator],\n","    color=\"steelblue\", linewidth=2.5, marker=\"o\", markersize=6,\n","    label=\"Actual\"\n",")\n","\n","# Target line (dashed)\n","ax.plot(\n","    df[\"Year\"], target_line,\n","    color=\"crimson\", linewidth=2, linestyle=\"--\",\n","    label=f\"Vision 2030 Target ({target_value}%)\"\n",")\n","\n","# Shade the gap between actual and target\n","ax.fill_between(\n","    df[\"Year\"], df[indicator], target_line,\n","    alpha=0.08, color=\"crimson\", label=\"Gap to Target\"\n",")\n","\n","# Labels and formatting\n","ax.set_title(\"Non-Oil GDP Growth: Actual vs Vision 2030 Target\", fontsize=14, fontweight=\"bold\", pad=15)\n","ax.set_xlabel(\"Year\", fontsize=11)\n","ax.set_ylabel(\"Growth (%)\", fontsize=11)\n","ax.yaxis.set_major_formatter(mtick.PercentFormatter(xmax=100, decimals=1))\n","ax.set_xticks(years)\n","ax.tick_params(axis=\"x\", rotation=45)\n","ax.legend(fontsize=10)\n","ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.4)\n","\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"\\n✅ Chart rendered. Replace mock data and targets with real values to go live.\")"]},{"cell_type":"code","source":["# ============================================================\n","# Saudi Vision 2030 Dashboard — Real World Bank Data\n","# ============================================================\n","\n","# PART 1: Install and import dependencies\n","# wbdata is a Python wrapper for the World Bank API\n","!pip install wbdata --quiet\n","\n","import wbdata\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import matplotlib.ticker as mtick\n","import datetime\n","import warnings\n","warnings.filterwarnings(\"ignore\")\n","\n","# ============================================================\n","# PART 2: Define indicators and fetch from World Bank API\n","# ============================================================\n","# These are the official World Bank indicator codes for Saudi Arabia.\n","\n","indicators = {\n","    \"NY.GDP.MKTP.KD.ZG\":    \"gdp_growth\",        # Total GDP growth (annual %)\n","    \"NY.GDP.PETR.RT.ZS\":    \"oil_rents_pct_gdp\", # Oil rents as % of GDP\n","    \"SL.EMP.TOTL.SP.NE.ZS\": \"employment_rate\",   # Employment-to-population ratio (%)\n","    \"BX.KLT.DINV.WD.GD.ZS\": \"FDI_pct_GDP\",       # FDI net inflows (% of GDP)\n","}\n","\n","# Fetch data for Saudi Arabia from 2015 to present\n","date_range = (datetime.datetime(2015, 1, 1), datetime.datetime(2024, 12, 31))\n","\n","print(\"⏳ Fetching data from World Bank API...\")\n","raw = wbdata.get_dataframe(indicators, country=\"SAU\", date=date_range)\n","\n","# Reset index so Year becomes a column; reverse so oldest year is first\n","df_raw = raw.reset_index()\n","df_raw = df_raw.rename(columns={\"date\": \"Year\"})\n","df_raw[\"Year\"] = df_raw[\"Year\"].astype(int)\n","df_raw = df_raw.sort_values(\"Year\").reset_index(drop=True)\n","\n","print(\"✅ Raw data fetched:\")\n","print(df_raw.to_string(index=False))\n","\n","# ============================================================\n","# PART 3: Approximate non-oil GDP growth\n","# ============================================================\n","# APPROXIMATION NOTE:\n","# True non-oil GDP growth requires national accounts data broken down by\n","# oil vs. non-oil sectors (published by GASTAT, not the World Bank).\n","# The formula below is a commonly used simplification:\n","#\n","#   non_oil_GDP_growth ≈ total_GDP_growth − Δ(oil_rents_pct_GDP)\n","#\n","# The logic: if oil rents as a share of GDP fell by X pp year-on-year,\n","# the non-oil economy likely grew faster than the headline figure.\n","# This is directionally useful but NOT a substitute for GASTAT data.\n","# Replace this column with official GASTAT figures when available.\n","\n","df_raw[\"oil_rents_change\"] = df_raw[\"oil_rents_pct_gdp\"].diff()  # year-on-year change in oil rents share\n","df_raw[\"non_oil_GDP_growth\"] = df_raw[\"gdp_growth\"] - df_raw[\"oil_rents_change\"]\n","\n","# ============================================================\n","# PART 4: Build the clean dashboard DataFrame\n","# ============================================================\n","# Saudization rate is left as NaN — fill in manually from GASTAT reports.\n","# Official GASTAT source: https://www.stats.gov.sa\n","\n","df = pd.DataFrame({\n","    \"Year\":              df_raw[\"Year\"],\n","    \"non_oil_GDP_growth\": df_raw[\"non_oil_GDP_growth\"].round(2),\n","    \"employment_rate\":    df_raw[\"employment_rate\"].round(2),\n","    \"FDI_pct_GDP\":        df_raw[\"FDI_pct_GDP\"].round(2),\n","    \"saudization_rate\":   None,   # ← Add manually from GASTAT Labour Market Reports\n","})\n","\n","print(\"\\n✅ Clean dashboard DataFrame:\")\n","print(df.to_string(index=False))\n","print(\"\\n  Note: non_oil_GDP_growth is an approximation (see comment above).\")\n","print(\"  Note: saudization_rate is empty — fill manually from GASTAT data.\")\n","\n","# ============================================================\n","# PART 5: Vision 2030 official targets\n","# ============================================================\n","# Sources:\n","#   · Vision 2030 document (vision2030.gov.sa)\n","#   · National Investment Strategy 2030\n","#   · Saudi Green Initiative / NTP 2025 KPIs\n","#\n","# These are the most widely cited official end-state targets by 2030.\n","\n","targets = {\n","    \"non_oil_GDP_growth\": 6.0,   # NTP target: ~6% annual non-oil growth\n","    \"employment_rate\":    70.0,  # Vision 2030: raise to 70% (from ~40% in 2016 baseline)\n","    \"FDI_pct_GDP\":        5.7,   # National Investment Strategy: FDI to reach 5.7% of GDP\n","    \"saudization_rate\":   None,  # Sector-specific; no single national % target published\n","}\n","\n","print(\"\\n✅ Vision 2030 Targets:\")\n","for k, v in targets.items():\n","    print(f\"  {k}: {v if v is not None else 'sector-specific — set manually'}\")\n","\n","# ============================================================\n","# PART 6: Chart — Non-Oil GDP Growth: Actual vs Target\n","# ============================================================\n","\n","plot_df = df.dropna(subset=[\"non_oil_GDP_growth\"])  # skip years with missing data\n","\n","fig, ax = plt.subplots(figsize=(11, 5))\n","\n","ax.plot(\n","    plot_df[\"Year\"], plot_df[\"non_oil_GDP_growth\"],\n","    color=\"steelblue\", linewidth=2.5, marker=\"o\", markersize=6,\n","    label=\"Actual (approx.)\"\n",")\n","\n","target_val  = targets[\"non_oil_GDP_growth\"]\n","target_line = [target_val] * len(plot_df)\n","\n","ax.plot(\n","    plot_df[\"Year\"], target_line,\n","    color=\"crimson\", linewidth=2, linestyle=\"--\",\n","    label=f\"Vision 2030 Target ({target_val}%)\"\n",")\n","\n","ax.fill_between(\n","    plot_df[\"Year\"], plot_df[\"non_oil_GDP_growth\"], target_line,\n","    alpha=0.08, color=\"crimson\"\n",")\n","\n","ax.set_title(\n","    \"Saudi Arabia — Non-Oil GDP Growth vs Vision 2030 Target\\n\"\n","    \"(Approximation: Total GDP Growth − ΔOil Rents | Source: World Bank)\",\n","    fontsize=13, fontweight=\"bold\", pad=12\n",")\n","ax.set_xlabel(\"Year\", fontsize=11)\n","ax.set_ylabel(\"Growth (%)\", fontsize=11)\n","ax.yaxis.set_major_formatter(mtick.PercentFormatter(xmax=100, decimals=1))\n","ax.set_xticks(plot_df[\"Year\"])\n","ax.tick_params(axis=\"x\", rotation=45)\n","ax.legend(fontsize=10)\n","ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.4)\n","\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"\\n✅ Done. Next step: replace non_oil_GDP_growth with GASTAT official figures.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":848},"id":"08iH_ZgV69fy","executionInfo":{"status":"ok","timestamp":1774843746359,"user_tz":-300,"elapsed":22169,"user":{"displayName":"More Wagan","userId":"17960663785126807612"}},"outputId":"27bf7bdd-5b18-4645-92bc-95476080e4cf"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m300.4/300.4 kB\u001b[0m \u001b[31m70.2 kB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25h\u001b[31mERROR: pip's dependency resolver does not currently take into account all the packages that are installed. This behaviour is the source of the following dependency conflicts.\n","ipython 7.34.0 requires jedi>=0.16, which is not installed.\n","moviepy 1.0.3 requires decorator<5.0,>=4.0.2, but you have decorator 5.2.1 which is incompatible.\u001b[0m\u001b[31m\n","\u001b[0m⏳ Fetching data from World Bank API...\n","✅ Raw data fetched:\n"," Year  gdp_growth  oil_rents_pct_gdp  employment_rate  FDI_pct_GDP\n"," 2015    4.655123          23.956799           51.000     0.572622\n"," 2016    1.704047          20.005177              NaN     3.185186\n"," 2017    1.182107          23.617072           51.671     0.136801\n"," 2018    3.226951          28.084281           52.608     1.369457\n"," 2019    1.651589          24.329578           54.627     0.346411\n"," 2020   -3.804789          15.978911           54.963     0.211116\n"," 2021    6.519597          23.686294           57.105     2.885061\n"," 2022   12.000587                NaN           57.645     2.155645\n"," 2023    0.542592                NaN           63.931     1.871