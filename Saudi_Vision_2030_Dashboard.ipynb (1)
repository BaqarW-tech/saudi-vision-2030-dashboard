     -1.24              False\n"," 2019                5.41              False\n"," 2020                4.55              False\n"," 2021               -1.19              False\n"," 2022                5.40              False\n"," 2023                4.60              False\n"," 2024                3.80              False\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# STEP 3: Add Saudization Rates\n","# Source: GASTAT Labour Market Surveys & MHRSD Annual Reports\n","# Note on reliability: These figures are approximations compiled\n","# from published GASTAT/MHRSD press releases. Official granular\n","# time-series data is not freely available via API; treat as\n","# indicative rather than audit-grade. Always cite source when\n","# presenting publicly.\n","# ============================================================\n","\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","import matplotlib.patches as mpatches\n","\n","# --- 3a. Hardcoded Saudization data ---\n","# % of Saudi nationals among private sector employees\n","# Sources: GASTAT Labour Market Bulletins (2016-2022),\n","#          MHRSD Nitaqat Programme Reports (2022-2024)\n","\n","saudization_data = {\n","    \"Year\":              [2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024],\n","    \"Saudization_rate\":  [17.8, 18.1, 18.9, 19.9, 21.5, 23.4, 25.1, 26.8, 28.4],\n","}\n","\n","df_saud = pd.DataFrame(saudization_data)\n","\n","# --- 3b. Merge into existing df ---\n","# Left join so we keep all years already in df\n","df = df.merge(df_saud, on=\"Year\", how=\"left\")\n","\n","print(\"✅ Saudization merged. DataFrame now:\")\n","print(df[[\"Year\", \"non_oil_GDP_growth\", \"employment_rate\",\n","          \"FDI_pct_GDP\", \"Saudization_rate\"]].to_string(index=False))\n","\n","# --- 3c. Vision 2030 target ---\n","SAUDIZATION_TARGET = 45.0   # % Saudi nationals in private sector by 2030\n","                             # Source: Vision 2030 Human Capability Development Programme\n","\n","# --- 3d. Line chart ---\n","fig, ax = plt.subplots(figsize=(10, 5))\n","\n","# Actual line\n","ax.plot(df[\"Year\"], df[\"Saudization_rate\"],\n","        marker=\"o\", linewidth=2, color=\"#1a6fa8\", label=\"Actual\")\n","\n","# Target line\n","ax.axhline(y=SAUDIZATION_TARGET, color=\"red\", linestyle=\"--\",\n","           linewidth=1.5, label=f\"Vision 2030 Target ({SAUDIZATION_TARGET}%)\")\n","\n","# Shade the gap\n","ax.fill_between(df[\"Year\"], df[\"Saudization_rate\"], SAUDIZATION_TARGET,\n","                alpha=0.08, color=\"red\", label=\"Gap to target\")\n","\n","# Labels & formatting\n","ax.set_title(\"Saudization Rate: Actual vs Vision 2030 Target\\n\"\n","             \"(% Saudi Nationals in Private Sector)\", fontsize=13, fontweight=\"bold\")\n","ax.set_xlabel(\"Year\", fontsize=11)\n","ax.set_ylabel(\"Saudization Rate (%)\", fontsize=11)\n","ax.set_xticks(df[\"Year\"])\n","ax.set_ylim(0, 55)\n","ax.legend(fontsize=10)\n","ax.grid(axis=\"y\", linestyle=\":\", alpha=0.5)\n","\n","# Annotate latest value\n","latest = df.dropna(subset=[\"Saudization_rate\"]).iloc[-1]\n","ax.annotate(f'{latest[\"Saudization_rate\"]:.1f}%',\n","            xy=(latest[\"Year\"], latest[\"Saudization_rate\"]),\n","            xytext=(8, 6), textcoords=\"offset points\", fontsize=9, color=\"#1a6fa8\")\n","\n","# Data source note\n","fig.text(0.01, -0.03,\n","         \"Sources: GASTAT Labour Market Bulletins; MHRSD Nitaqat Programme Reports.\\n\"\n","         \"Note: Figures are approximations from published press releases. \"\n","         \"Not audit-grade — cite source when presenting.\",\n","         fontsize=7.5, color=\"gray\", ha=\"left\")\n","\n","plt.tight_layout()\n","plt.show()\n","\n","print(f\"\\n📊 Latest Saudization rate ({int(latest['Year'])}): {latest['Saudization_rate']}%\")\n","print(f\"   Vision 2030 Target: {SAUDIZATION_TARGET}%\")\n","print(f\"   Gap remaining: {SAUDIZATION_TARGET - latest['Saudization_rate']:.1f} percentage points\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":413},"id":"OjMmWNqOSSAT","executionInfo":{"status":"ok","timestamp":1774851045375,"user_tz":-300,"elapsed":2169,"user":{"displayName":"More Wagan","userId":"17960663785126807612"}},"outputId":"f4df4ba7-d1f8-4ab6-c6a0-d29324d8bd6f"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Saudization merged. DataFrame now:\n"," Year  non_oil_GDP_growth  employment_rate  FDI_pct_GDP  Saudization_rate\n"," 2016                5.66              NaN         3.19              17.8\n"," 2017               -2.43            51.67         0.14              18.1\n"," 2018               -1.24            52.61         1.37              18.9\n"," 2019                5.41            54.63         0.35              19.9\n"," 2020                4.55            54.96         0.21              21.5\n"," 2021               -1.19            57.10         2.89              23.4\n"," 2022               12.00            57.64         2.16              25.1\n"," 2023                0.54            63.93         1.87              26.8\n"," 2024                2.00            63.96         1.72              28.4\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","📊 Latest Saudization rate (2024): 28.4%\n","   Vision 2030 Target: 45.0%\n","   Gap remaining: 16.6 percentage points\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# STEP 4: Full Vision 2030 Dashboard — Four-Panel Chart\n","# ============================================================\n","\n","import matplotlib.pyplot as plt\n","import matplotlib.gridspec as gridspec\n","import matplotlib.patches as mpatches\n","import numpy as np\n","\n","# --- Targets ---\n","TARGETS = {\n","    \"non_oil_GDP_growth\": 6.0,   # Vision 2030: diversify economy, 6% non-oil growth\n","    \"employment_rate\":    70.0,  # Vision 2030: raise employment-to-population to 70%\n","    \"FDI_pct_GDP\":         5.7,  # Vision 2030: FDI to reach 5.7% of GDP\n","    \"Saudization_rate\":   45.0,  # Human Capability Development Programme target\n","}\n","\n","LABELS = {\n","    \"non_oil_GDP_growth\": (\"Non-Oil GDP Growth (%)\",      \"#2166ac\"),\n","    \"employment_rate\":    (\"Employment Rate (%)\",          \"#4dac26\"),\n","    \"FDI_pct_GDP\":        (\"FDI Inflows (% of GDP)\",       \"#d6604d\"),\n","    \"Saudization_rate\":   (\"Saudization Rate (%)\",         \"#8B5CF6\"),\n","}\n","\n","# Columns with known approximation issues — will be flagged\n","APPROXIMATED_YEARS = {\n","    \"non_oil_GDP_growth\": df.loc[df[\"oil_rents_imputed\"] == True, \"Year\"].tolist()\n","                          if \"oil_rents_imputed\" in df.columns else [],\n","}\n","\n","# ---- Build figure ----\n","fig = plt.figure(figsize=(16, 11))\n","fig.patch.set_facecolor(\"#F8F9FA\")\n","\n","gs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.45, wspace=0.32)\n","\n","for idx, (col, target) in enumerate(TARGETS.items()):\n","    ax = fig.add_subplot(gs[idx // 2, idx % 2])\n","    ax.set_facecolor(\"white\")\n","\n","    label, color = LABELS[col]\n","    plot_df = df[[\"Year\", col]].dropna()\n","\n","    # --- Main line ---\n","    ax.plot(plot_df[\"Year\"], plot_df[col],\n","            marker=\"o\", linewidth=2, color=color,\n","            markersize=5, zorder=3, label=\"Actual\")\n","\n","    # --- Flag approximated points (non-oil GDP only) ---\n","    approx_years = APPROXIMATED_YEARS.get(col, [])\n","    if approx_years:\n","        approx_df = plot_df[plot_df[\"Year\"].isin(approx_years)]\n","        ax.plot(approx_df[\"Year\"], approx_df[col],\n","                linestyle=\"--\", linewidth=1.5, color=color,\n","                alpha=0.55, zorder=2)\n","        ax.scatter(approx_df[\"Year\"], approx_df[col],\n","                   marker=\"x\", s=60, color=color, alpha=0.55, zorder=4,\n","                   label=\"Estimated (imputed oil rents)\")\n","\n","    # --- Target line ---\n","    ax.axhline(y=target, color=\"red\", linestyle=\"--\",\n","               linewidth=1.4, zorder=2, label=f\"2030 Target ({target}%)\")\n","\n","    # --- Shade gap in final year ---\n","    last_val = plot_df[col].iloc[-1]\n","    last_year = plot_df[\"Year\"].iloc[-1]\n","    gap_color = \"green\" if last_val >= target else \"red\"\n","    ax.fill_between(plot_df[\"Year\"], plot_df[col], target,\n","                    alpha=0.06, color=gap_color)\n","\n","    # --- Annotate latest value ---\n","    ax.annotate(f\"{last_val:.1f}%\",\n","                xy=(last_year, last_val),\n","                xytext=(6, 5), textcoords=\"offset points\",\n","                fontsize=8.5, color=color, fontweight=\"bold\")\n","\n","    # --- Annotate target ---\n","    ax.annotate(f\"Target: {target}%\",\n","                xy=(plot_df[\"Year\"].iloc[0], target),\n","                xytext=(4, 4), textcoords=\"offset points\",\n","                fontsize=7.5, color=\"red\", alpha=0.8)\n","\n","    # --- Formatting ---\n","    ax.set_title(label, fontsize=11, fontweight=\"bold\", pad=8)\n","    ax.set_xlabel(\"Year\", fontsize=9)\n","    ax.set_ylabel(\"%\", fontsize=9)\n","    ax.set_xticks(plot_df[\"Year\"])\n","    ax.tick_params(axis=\"x\", rotation=45, labelsize=8)\n","    ax.tick_params(axis=\"y\", labelsize=8)\n","    ax.grid(axis=\"y\", linestyle=\":\", alpha=0.4)\n","    ax.spines[[\"top\", \"right\"]].set_visible(False)\n","    if approx_years:\n","        ax.legend(fontsize=7, loc=\"upper left\")\n","    else:\n","        ax.legend(fontsize=8, loc=\"upper left\")\n","\n","# --- Main title ---\n","fig.suptitle(\"Saudi Vision 2030 — Key Indicators Dashboard\",\n","             fontsize=15, fontweight=\"bold\", y=1.01, color=\"#1a1a2e\")\n","\n","# --- Source note ---\n","fig.text(0.01, -0.02,\n","         \"Sources: World Bank WDI (employment, FDI); GASTAT National Accounts (non-oil GDP overrides 2022–2024); \"\n","         \"GASTAT Labour Market Bulletins & MHRSD Nitaqat Reports (Saudization).\\n\"\n","         \"Note: Non-oil GDP approximated as total GDP growth minus oil rents change. \"\n","         \"Dashed/×-marked points use imputed oil rents — treat as indicative.\",\n","         fontsize=7.5, color=\"gray\", ha=\"left\")\n","\n","plt.savefig(\"vision2030_dashboard.png\", dpi=150, bbox_inches=\"tight\",\n","            facecolor=fig.get_facecolor())\n","plt.show()\n","print(\"✅ Dashboard saved as vision2030_dashboard.png\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":227},"id":"HbHcS1WaX9sm","executionInfo":{"status":"ok","timestamp":1774851206411,"user_tz":-300,"elapsed":8837,"user":{"displayName":"More Wagan","userId":"17960663785126807612"}},"outputId":"e79ea952-6e9a-4831-8594-4c847ef9a827"},"execution_count":6,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1100 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["✅ Dashboard saved as vision2030_dashboard.png\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# STEP 4b: Progress Scorecard Table\n","# ============================================================\n","\n","scorecard_rows = []\n","for col, target in TARGETS.items():\n","    label = LABELS[col][0]\n","    series = df[[\"Year\", col]].dropna()\n","    baseline = series[series[\"Year\"] == series[\"Year\"].min()][col].values[0]\n","    latest_val = series[col].iloc[-1]\n","    latest_year = int(series[\"Year\"].iloc[-1])\n","    gap = target - latest_val\n","    status = \"✅ On track\" if latest_val >= target * 0.85 else \"⚠️  Needs acceleration\"\n","\n","    scorecard_rows.append({\n","        \"Indicator\":    label,\n","        \"Baseline\":     f\"{baseline:.1f}%\",\n","        f\"Latest ({latest_year})\": f\"{latest_val:.1f}%\",\n","        \"2030 Target\":  f\"{target:.1f}%\",\n","        \"Gap\":          f\"{gap:+.1f} pp\",\n","        \"Status\":       status,\n","    })\n","\n","scorecard = pd.DataFrame(scorecard_rows)\n","print(\"\\n📊 Vision 2030 Progress Scorecard\")\n","print(\"=\" * 78)\n","print(scorecard.to_string(index=False))\n","print(\"=\" * 78)\n","print(\"\\nSummary: Saudi Arabia shows strongest progress on employment and Saudization,\")\n","print(\"but FDI and non-oil GDP growth remain well below 2030 targets,\")\n","print(\"requiring significant structural reform acceleration.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IDflK04MYBlJ","executionInfo":{"status":"ok","timestamp":1774851208337,"user_tz":-300,"elapsed":45,"user":{"displayName":"More Wagan","userId":"17960663785126807612"}},"outputId":"dde3c760-e3dc-40cb-c94a-6c8c248d2c94"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","📊 Vision 2030 Progress Scorecard\n","==============================================================================\n","             Indicator Baseline Latest (2024) 2030 Target      Gap                 Status\n","Non-Oil GDP Growth (%)     5.7%          2.0%        6.0%  +4.0 pp ⚠️  Needs acceleration\n","   Employment Rate (%)    51.7%         64.0%       70.0%  +6.0 pp             ✅ On track\n","FDI Inflows (% of GDP)     3.2%          1.7%        5.7%  +4.0 pp ⚠️  Needs acceleration\n","  Saudization Rate (%)    17.8%         28.4%       45.0% +16.6 pp ⚠️  Needs acceleration\n","==============================================================================\n","\n","Summary: Saudi Arabia shows strongest progress on employment and Saudization,\n","but FDI and non-oil GDP growth remain well below 2030 targets,\n","requiring significant structural reform acceleration.\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# STEP 5: AI-Powered Policy Analysis (f-string report)\n","# ============================================================\n","\n","# Pull live numbers from df for the report\n","emp_latest   = df[\"employment_rate\"].dropna().iloc[-1]\n","emp_baseline = df[\"employment_rate\"].dropna().iloc[0]\n","emp_gain     = emp_latest - emp_baseline\n","\n","fdi_latest   = df[\"FDI_pct_GDP\"].dropna().iloc[-1]\n","fdi_target   = TARGETS[\"FDI_pct_GDP\"]\n","fdi_gap      = fdi_target - fdi_latest\n","\n","noil_latest  = df[\"non_oil_GDP_growth\"].dropna().iloc[-1]\n","noil_target  = TARGETS[\"non_oil_GDP_growth\"]\n","\n","saud_latest  = df[\"Saudization_rate\"].dropna().iloc[-1]\n","saud_target  = TARGETS[\"Saudization_rate\"]\n","saud_gap     = saud_target - saud_latest\n","\n","report = f\"\"\"\n","╔══════════════════════════════════════════════════════════════════╗\n","   SAUDI VISION 2030 — POLICY ANALYSIS BRIEF (Data: 2016–2024)\n","╚══════════════════════════════════════════════════════════════════╝\n","\n","KEY FINDINGS\n","────────────\n","▸ Employment (STRONGEST PERFORMER)\n","  Employment-to-population ratio rose from {emp_baseline:.1f}% to {emp_latest:.1f}%\n","  — a {emp_gain:.1f} percentage point gain. This is the only indicator\n","  tracking within 85% of its 2030 target ({TARGETS['employment_rate']}%).\n","  Driven by female labour force participation reforms post-2017\n","  and the Nitaqat quota system.\n","\n","▸ Saudization (IMPROVING BUT LARGE GAP)\n","  Private-sector Saudi employment share reached {saud_latest:.1f}%, up from\n","  17.8% in 2016 — nearly doubling. However, the gap to the\n","  {saud_target:.0f}% target remains {saud_gap:.1f} percentage points. At the\n","  current pace of ~1.3 pp/year, the target would be reached around 2037,\n","  seven years late.\n","\n","▸ FDI Inflows (CRITICAL UNDERPERFORMANCE)\n","  FDI fell to {fdi_latest:.1f}% of GDP in 2024, against a target of\n","  {fdi_target:.1f}%. Despite headline giga-project announcements (NEOM,\n","  Red Sea, Qiddiya), committed foreign capital as a share of GDP\n","  remains low. A key structural constraint is investor uncertainty\n","  around regulatory consistency and contract enforcement.\n","\n","▸ Non-Oil GDP Growth (VOLATILE, BELOW TARGET)\n","  Growth of {noil_latest:.1f}% in 2024 is well below the {noil_target:.1f}% target.\n","  Post-2022 deceleration reflects the fading of post-COVID rebound\n","  effects. Sustained diversification requires private-sector depth\n","  beyond construction and government-linked entities.\n","\n","POLICY RECOMMENDATIONS\n","──────────────────────\n","1. FDI: Accelerate Companies Law reforms and establish an\n","   independent commercial arbitration authority to reduce\n","   investor risk perception.\n","\n","2. Non-Oil Growth: Shift giga-project spending toward\n","   SME supply-chain integration to broaden the non-oil\n","   productive base beyond flagship developments.\n","\n","3. Saudization: Current Nitaqat quotas incentivise\n","   box-ticking over genuine skill transfer. Introduce\n","   productivity-linked Saudization credits tied to\n","   training certification outcomes.\n","\n","DATA CAVEATS\n","────────────\n","• Non-oil GDP figures for 2017–2021 use World Bank approximation\n","  (total GDP growth minus oil rents change). GASTAT overrides\n","  applied for 2022–2024.\n","• Saudization figures compiled from GASTAT/MHRSD press releases —\n","  not a continuous official time series.\n","• FDI data from World Bank WDI; may lag actual inflows by 1–2 years.\n","\n","━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n","Analysis produced using Python (pandas, matplotlib) + Claude AI.\n","Data: World Bank WDI, GASTAT, MHRSD. Author: Mor Wagan, MA Economics.\n","━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n","\"\"\"\n","\n","print(report)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GamKPUGvYrsU","executionInfo":{"status":"ok","timestamp":177485